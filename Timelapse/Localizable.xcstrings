    "Arkadaşını davet et; aynı projeye ikiniz de kare ekleyin, önceki kareleri birlikte görün": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invite a friend; you both add frames to the same project and see all previous frames together"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lade Freunde ein; ihr fügt beide Bilder zum selben Projekt hinzu und seht alle bisherigen Bilder gemeinsam"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Invita a un amigo; ambos añadís fotos al mismo proyecto y veis juntos las fotos anteriores"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Invite un ami ; vous ajoutez tous les deux des photos au même projet et voyez ensemble les photos précédentes"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Convide um amigo; vocês dois adicionam fotos ao mesmo projeto e veem juntos as fotos anteriores"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दोस्त को न्योता दें; दोनों एक ही प्रोजेक्ट में फ़ोटो जोड़ें और पिछली फ़ोटो साथ देखें"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "邀请朋友；你们都可以向同一项目添加照片，并一起查看之前的照片"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "友だちを招待して、同じプロジェクトにふたりで写真を追加。これまでの写真もいっしょに見られます"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ادعُ صديقًا؛ يضيف كلاكما صورًا إلى المشروع نفسه وتشاهدان الصور السابقة معًا"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пригласите друга: вы оба добавляете кадры в один проект и вместе видите все прошлые кадры"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "친구를 초대하세요. 둘 다 같은 프로젝트에 사진을 추가하고 이전 사진도 함께 볼 수 있어요"
          }
        }
      }
    },
    "Davet linkiyle aynı projeye birlikte çekin": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture together on the same project via an invite link"

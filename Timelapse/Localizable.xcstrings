    "%@ için bugünkü kareni ekle.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add today's frame for %@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge das heutige Bild für %@ hinzu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade la foto de hoy para %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute la photo du jour pour %@."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione a foto de hoje para %@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ के लिए आज की फ़ोटो जोड़ें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为 %@ 添加今天的照片。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ の今日の1枚を追加しましょう。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضِف صورة اليوم لـ %@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте сегодняшний кадр для %@."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@의 오늘 사진을 추가하세요."
          }
        }
      }
    },

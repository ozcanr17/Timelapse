    "Günlük, gün aşırı ya da haftalık — zamanı gelince hatırlatırız": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Daily, every other day, or weekly — we remind you when it's time"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Täglich, jeden zweiten Tag oder wöchentlich — wir erinnern dich rechtzeitig"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Diario, cada dos días o semanal — te recordamos cuando toque"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque jour, un jour sur deux ou chaque semaine — on te le rappelle au bon moment"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Diário, dia sim dia não ou semanal — lembramos você na hora certa"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रोज़, एक दिन छोड़कर या हफ़्ते में — समय आने पर याद दिलाएँगे"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每天、隔天或每周 — 到点我们会提醒你"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "毎日・1日おき・毎週 — 時間になったらお知らせします"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يوميًا أو يومًا بعد يوم أو أسبوعيًا — نذكّرك في الوقت المناسب"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждый день, через день или раз в неделю — мы напомним вовремя"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "매일, 이틀에 한 번, 매주 — 때가 되면 알려드려요"
          }
        }
      }
    },

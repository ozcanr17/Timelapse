    "Karelerin akıcı bir videoya dönüşsün; anında paylaş": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn your frames into a smooth video and share it instantly"
          }
        },
        "de": {

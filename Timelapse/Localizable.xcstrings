    },
    "iCloud yedekleme açıldı. Projelerinin eşitlenmesi için uygulamayı kapatıp yeniden aç.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud backup is on. Quit and reopen the app to sync your projects."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud-Backup ist aktiv. Beende die App und öffne sie erneut, um deine Projekte zu synchronisieren."
          }
        },
        "es": {
          "stringUnit": {

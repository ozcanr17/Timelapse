          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई हटाया गया प्रोजेक्ट नहीं"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有已删除的项目"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除したプロジェクトはありません"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد مشاريع محذوفة"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет удалённых проектов"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삭제된 프로젝트가 없어요"
          }
        }
      }
    },
    "Silinen projeler 30 gün saklanır, sonra kalıcı olarak silinir. iCloud yedekleme açıksa bu süre boyunca iCloud'da da saklanırlar.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleted projects are kept for 30 days, then removed permanently. If iCloud backup is on, they are also kept in iCloud during this period."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelöschte Projekte werden 30 Tage aufbewahrt und dann endgültig gelöscht. Bei aktivem iCloud-Backup bleiben sie in dieser Zeit auch in iCloud erhalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los proyectos eliminados se conservan 30 días y luego se borran permanentemente. Con la copia de iCloud activada, también se conservan en iCloud durante ese período."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les projets supprimés sont conservés 30 jours puis effacés définitivement. Si la sauvegarde iCloud est active, ils restent aussi dans iCloud pendant cette période."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Projetos apagados são mantidos por 30 dias e depois excluídos permanentemente. Com o backup do iCloud ativo, também ficam no iCloud durante esse período."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हटाए गए प्रोजेक्ट 30 दिन रखे जाते हैं, फिर हमेशा के लिए हट जाते हैं। iCloud बैकअप चालू होने पर इस अवधि में वे iCloud में भी रहते हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已删除的项目会保留 30 天，之后永久删除。若开启 iCloud 备份，此期间也会保留在 iCloud 中。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除したプロジェクトは30日間保管され、その後完全に削除されます。iCloud バックアップが有効なら、この期間中は iCloud にも保管されます。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُحفظ المشاريع المحذوفة لمدة 30 يومًا ثم تُحذف نهائيًا. وإذا كان نسخ iCloud الاحتياطي مفعّلًا، تُحفظ أيضًا في iCloud خلال هذه المدة."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалённые проекты хранятся 30 дней, затем удаляются навсегда. При включённой резервной копии iCloud они также хранятся в iCloud в этот период."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삭제된 프로젝트는 30일간 보관된 뒤 영구 삭제됩니다. iCloud 백업이 켜져 있으면 이 기간 동안 iCloud에도 보관됩니다."
          }
        }
      }
    }
  },
  "version": "1.0"
}
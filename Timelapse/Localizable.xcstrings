    "Silinen proje yok": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No deleted projects"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine gelöschten Projekte"
          }
        },

    "Kamera izni verilmedi. Ayarlar’dan açabilirsin.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access wasn't granted. You can enable it in Settings."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamerazugriff nicht erlaubt. Du kannst ihn in den Einstellungen aktivieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se concedió acceso a la cámara. Puedes activarlo en Ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès à la caméra n'a pas été accordé. Tu peux l'activer dans Réglages."

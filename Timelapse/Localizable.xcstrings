    "Önceki karen kameranın üzerinde silik görünür; her fotoğraf aynı açıdan çekilir": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your previous frame shows faintly over the camera, so every photo lines up the same way"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein voriges Bild erscheint blass über der Kamera; jedes Foto gelingt aus demselben Winkel"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu foto anterior aparece tenue sobre la cámara; cada foto sale desde el mismo ángulo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta photo précédente apparaît en filigrane sur la caméra ; chaque photo garde le même angle"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua foto anterior aparece translúcida sobre a câmera; cada foto sai do mesmo ângulo"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिछली फ़ोटो कैमरे पर हल्की दिखती है; हर फ़ोटो एक ही कोण से आती है"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "上一张照片会淡淡地叠在取景器上；每张照片都保持同一角度"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前回の写真がカメラにうっすら重なり、毎回同じアングルで撮れます"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر صورتك السابقة شفافة فوق الكاميرا؛ فتلتقط كل صورة من الزاوية نفسها"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прошлый кадр слегка виден поверх камеры — каждое фото получается с того же ракурса"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이전 사진이 카메라 위에 흐릿하게 겹쳐 보여 매번 같은 각도로 찍을 수 있어요"
          }
        }
      }
    },

    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يلزم الوصول إلى الكاميرا لالتقاط صور تقدّمك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Kamerazugriff wird benötigt, um deine Fortschrittsfotos aufzunehmen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Camera access is needed to take your progress photos."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se necesita acceso a la cámara para tomar tus fotos de progreso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès à la caméra est nécessaire pour prendre tes photos de progression."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी प्रगति की फ़ोटो लेने के लिए कैमरा एक्सेस चाहिए।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "進捗写真を撮影するためにカメラへのアクセスが必要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "진행 사진을 찍으려면 카메라 접근이 필요합니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O acesso à câmera é necessário para tirar suas fotos de progresso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ к камере нужен, чтобы снимать фото вашего прогресса."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gelişim fotoğraflarını çekmek için kameraya erişim gerekir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要访问相机来拍摄你的进度照片。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُستخدم موقعك لوسم صورك بالمكان الذي التُقطت فيه."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Standort wird verwendet, um Aufnahmen mit dem Ort zu versehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your location is used to tag your captures with the place they were taken."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu ubicación se usa para etiquetar tus capturas con el lugar donde se tomaron."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ta position sert à associer tes prises au lieu où elles ont été faites."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी लोकेशन का उपयोग फ़ोटो में जगह जोड़ने के लिए होता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "撮影場所を写真に記録するために位置情報を使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사진에 촬영 장소를 기록하기 위해 위치 정보를 사용합니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sua localização é usada para marcar suas capturas com o local onde foram tiradas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваше местоположение используется, чтобы отмечать место съёмки на кадрах."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Çekimlerinize yer bilgisi eklemek için konuma erişim gerekir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的位置用于为照片标注拍摄地点。"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "comment" : "Privacy - Photo Library Additions Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يلزم الوصول لحفظ صورك وفيديوهات التايم لابس في مكتبة الصور."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Zugriff wird benötigt, um Bilder und Zeitraffer-Videos in deiner Fotomediathek zu sichern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Access is needed to save your frames and timelapse videos to your photo library."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se necesita acceso para guardar tus fotos y vídeos timelapse en tu biblioteca."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès est nécessaire pour enregistrer tes photos et vidéos timelapse dans ta photothèque."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "फ़ोटो और टाइमलैप्स वीडियो आपकी लाइब्रेरी में सहेजने के लिए एक्सेस चाहिए।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真やタイムラプス動画をフォトライブラリに保存するためにアクセスが必要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사진과 타임랩스 영상을 사진 보관함에 저장하려면 접근 권한이 필요합니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O acesso é necessário para salvar suas fotos e vídeos timelapse na sua biblioteca."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ нужен, чтобы сохранять кадры и таймлапс-видео в вашу медиатеку."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kareleri ve timelapse videolarını fotoğraflarına kaydetmek için erişim gerekir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要访问权限以将照片和延时视频存储到你的照片图库。"
          }
        }
      }
    },
      "NSPhotoLibraryUsageDescription" : {
          "comment" : "Privacy - Photo Library Usage Description",
          "extractionState" : "extracted_with_value",
          "localizations" : {
              "ar" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "يلزم الوصول لقراءة تاريخ التقاط الصور وموقعها عند استيرادها."
                  }
              },
              "de" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "Der Zugriff wird benötigt, um beim Import Aufnahmedatum und Standort der Fotos zu lesen."
                  }
              },
              "en" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "Access is needed to read capture dates and locations when importing photos."
                  }
              },
              "es" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "Se necesita acceso para leer la fecha y la ubicación al importar fotos."
                  }
              },
              "fr" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "L’accès est nécessaire pour lire la date et le lieu de prise de vue lors de l’importation des photos."
                  }
              },
              "hi" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "फ़ोटो इंपोर्ट करते समय उनकी तारीख और स्थान पढ़ने के लिए एक्सेस चाहिए।"
                  }
              },
              "ja" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "写真の読み込み時に撮影日時と位置情報を取得するため、アクセスが必要です。"
                  }
              },
              "ko" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "사진을 가져올 때 촬영 날짜와 위치 정보를 읽으려면 접근 권한이 필요합니다."
                  }
              },
              "pt" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "É necessário acesso para ler a data e a localização ao importar fotografias."
                  }
              },
              "ru" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "Доступ нужен, чтобы при импорте фотографий считывать дату и место съёмки."
                  }
              },
              "tr" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "Fotoğraflardan içe aktarırken çekim tarihi ve konum bilgisini okumak için erişim gerekir."
                  }
              },
              "zh-Hans" : {
                  "stringUnit" : {
                      "state" : "translated",
                      "value" : "导入照片时，需要访问权限以读取拍摄日期和位置信息。"
                  }
              }
          }
      }
  },
  "version" : "1.0"

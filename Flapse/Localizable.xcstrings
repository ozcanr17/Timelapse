          }
        }
      }
    },
    "Apple ile giriş kaydın bu cihazdan ve iCloud'dan kaldırılır. Projelerin ve fotoğrafların cihazında kalır.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيُزال تسجيل الدخول بـ Apple من هذا الجهاز ومن iCloud. تبقى مشاريعك وصورك على جهازك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Anmeldung mit Apple wird von diesem Gerät und aus iCloud entfernt. Deine Projekte und Fotos bleiben auf dem Gerät."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Sign in with Apple record is removed from this device and iCloud. Your projects and photos stay on your device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu registro de inicio de sesión con Apple se elimina de este dispositivo y de iCloud. Tus proyectos y fotos permanecen en tu dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton enregistrement Connexion avec Apple est supprimé de cet appareil et d'iCloud. Tes projets et photos restent sur ton appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका Apple साइन-इन रिकॉर्ड इस डिवाइस और iCloud से हटा दिया जाएगा। आपके प्रोजेक्ट और फ़ोटो डिवाइस पर रहेंगे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleでサインインの記録がこのデバイスとiCloudから削除されます。プロジェクトと写真はデバイスに残ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 로그인 기록이 이 기기와 iCloud에서 제거됩니다. 프로젝트와 사진은 기기에 남습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu registro de Iniciar sessão com a Apple é removido deste dispositivo e do iCloud. Seus projetos e fotos permanecem no dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запись входа через Apple будет удалена с этого устройства и из iCloud. Проекты и фотографии останутся на устройстве."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 Apple 登录记录将从此设备和 iCloud 中移除。你的项目和照片会保留在设备上。"
          }
        }
      }
    },
    "Apple ile giriş şu an kullanılamıyor (ücretli Apple Developer hesabı gerekir). Test için sürüm numarasına 7 kez dokunup geliştirici arka kapısını kullan.": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تسجيل الدخول باستخدام Apple غير متاح حاليًا (يلزم حساب Apple Developer مدفوع). للاختبار، اضغط على رقم الإصدار 7 مرات واستخدم وضع المطور."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anmelden mit Apple ist derzeit nicht verfügbar (kostenpflichtiges Apple-Developer-Konto erforderlich). Zum Testen 7-mal auf die Versionsnummer tippen und die Entwickler-Hintertür verwenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in with Apple is unavailable (a paid Apple Developer account is required). To test, tap the version number 7 times and use the developer backdoor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar sesión con Apple no está disponible (se requiere una cuenta de pago de Apple Developer). Para probar, toca 7 veces el número de versión y usa la puerta trasera de desarrollador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion avec Apple est indisponible (compte Apple Developer payant requis). Pour tester, touche 7 fois le numéro de version et utilise la porte dérobée développeur."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple से साइन इन अभी उपलब्ध नहीं है (सशुल्क Apple Developer खाता आवश्यक है)। परीक्षण के लिए संस्करण संख्या पर 7 बार टैप करें और डेवलपर मोड का उपयोग करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleでサインインは現在利用できません（有料のApple Developerアカウントが必要です）。テストするにはバージョン番号を7回タップして開発者モードを使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 Apple로 로그인할 수 없습니다(유료 Apple Developer 계정 필요). 테스트하려면 버전 번호를 7번 탭한 후 개발자 모드를 사용하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar sessão com a Apple não está disponível neste momento (é necessária uma conta Apple Developer paga). Para testar, toque 7 vezes no número da versão e use o modo de programador."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вход с Apple сейчас недоступен (требуется платная учётная запись Apple Developer). Для тестирования нажмите на номер версии 7 раз и используйте режим разработчика."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“通过 Apple 登录”当前不可用（需要付费 Apple Developer 帐户）。如需测试，请连续轻点版本号 7 次并使用开发者模式。"
          }
        }
      }
    },
    "Arkadaşını davet et; aynı projeye ikiniz de kare ekleyin, önceki kareleri birlikte görün": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ادعُ صديقًا؛ يضيف كلاكما صورًا إلى المشروع نفسه وتشاهدان الصور السابقة معًا"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lade Freunde ein; ihr fügt beide Bilder zum selben Projekt hinzu und seht alle bisherigen Bilder gemeinsam"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invite a friend; you both add frames to the same project and see all previous frames together"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Invita a un amigo; ambos añadís fotos al mismo proyecto y veis juntos las fotos anteriores"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Invite un ami ; vous ajoutez tous les deux des photos au même projet et voyez ensemble les photos précédentes"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दोस्त को न्योता दें; दोनों एक ही प्रोजेक्ट में फ़ोटो जोड़ें और पिछली फ़ोटो साथ देखें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "友だちを招待して、同じプロジェクトにふたりで写真を追加。これまでの写真もいっしょに見られます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "친구를 초대하세요. 둘 다 같은 프로젝트에 사진을 추가하고 이전 사진도 함께 볼 수 있어요"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Convide um amigo; vocês dois adicionam fotos ao mesmo projeto e veem juntos as fotos anteriores"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пригласите друга: вы оба добавляете кадры в один проект и вместе видите все прошлые кадры"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "邀请朋友；你们都可以向同一项目添加照片，并一起查看之前的照片"
          }
        }
      }
    },

    "Proje ve içindeki tüm çekimler kalıcı olarak silinsin mi?": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد حذف المشروع وكل صوره نهائيًا؟"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Projekt und alle Aufnahmen darin endgültig löschen?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete this project and all of its shots permanently?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Eliminar permanentemente este proyecto y todas sus capturas?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer définitivement ce projet et toutes ses prises ?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह प्रोजेक्ट और इसकी सभी फ़ोटो हमेशा के लिए हटाएं?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このプロジェクトとすべての写真を完全に削除しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 프로젝트와 모든 사진을 영구 삭제할까요?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Excluir permanentemente este projeto e todas as suas capturas?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалить проект и все его снимки навсегда?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "永久删除该项目及其所有照片？"
          }
        }
      }
    },

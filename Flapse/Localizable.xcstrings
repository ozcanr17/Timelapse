        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte dein Motiv mit der Geister-Ausrichtung immer an derselben Stelle."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your subject in the same spot with ghost alignment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén el sujeto siempre en el mismo lugar con la alineación fantasma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez votre sujet au même endroit grâce à l'alignement fantôme."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "घोस्ट अलाइनमेंट से सब्जेक्ट को हमेशा एक ही जगह रखें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゴーストアライメントで被写体をいつも同じ位置に。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고스트 정렬로 피사체를 항상 같은 위치에 유지하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha o assunto sempre no mesmo lugar com o alinhamento fantasma."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держите объект на одном месте с помощью призрачного выравнивания."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用幽灵对齐让主体始终保持在同一位置。"
          }
        }
      }
    },

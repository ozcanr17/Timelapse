        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인 없이 계속"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Continuar sem iniciar sessão"
          }
        },
        "ru": {
          "stringUnit": {

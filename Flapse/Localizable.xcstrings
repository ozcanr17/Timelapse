          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हटाए गए टाइमलैप्स 7 दिनों तक रखे जाते हैं, फिर स्थायी रूप से हट जाते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",

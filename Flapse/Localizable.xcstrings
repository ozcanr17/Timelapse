    "Pro'da özneyi otomatik hizala; kareler pürüzsüz aksın": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حاذِ العنصر تلقائيًا مع Pro لتحصل على انتقال سلس بين اللقطات"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit Pro das Motiv automatisch ausrichten; Bilder fließen nahtlos"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-align the subject on Pro; frames flow smoothly"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Con Pro, alinea el sujeto automáticamente; las fotos fluyen suaves"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Avec Pro, aligne le sujet automatiquement ; les photos s'enchaînent en douceur"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro में विषय को अपने-आप संरेखित करें, ताकि फ़्रेम सहजता से बहें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Proなら被写体を自動で揃え、なめらかな映像に"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro에서 피사체를 자동 정렬해 프레임을 부드럽게 이어 보세요"
          }
        },
        "pt": {

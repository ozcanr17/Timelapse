          }
        }
      }
    },
    "Akıllı hizalama açık — özne karelere sabitlendi": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المحاذاة الذكية مفعّلة — تم تثبيت الهدف في كل الصور"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Smarte Ausrichtung aktiv — Motiv über alle Bilder fixiert"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Smart alignment on — subject locked across frames"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alineación inteligente activada — sujeto fijado en todas las fotos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alignement intelligent activé — sujet fixé sur toutes les photos"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्मार्ट अलाइनमेंट चालू — विषय सभी फ़ोटो में स्थिर"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スマート位置合わせオン — 被写体を全コマで固定"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스마트 정렬 켜짐 — 피사체가 모든 사진에 고정됨"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Alinhamento inteligente ativado — objeto fixado em todas as fotos"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Умное выравнивание включено — объект зафиксирован во всех кадрах"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能对齐已开启 — 主体已在所有照片中固定"
          }
        }
      }
    },
    "Akıllı hizalama özneyi her karede aynı yerde tutar.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المحاذاة الذكية تُبقي هدفك في المكان نفسه في كل إطار."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die smarte Ausrichtung hält dein Motiv in jedem Bild an derselben Stelle."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Smart alignment keeps your subject in the same spot in every frame."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La alineación inteligente mantiene el sujeto en el mismo lugar en cada fotograma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'alignement intelligent garde votre sujet au même endroit sur chaque image."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्मार्ट अलाइनमेंट हर फ्रेम में सब्जेक्ट को एक ही जगह रखता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スマートアライメントが被写体を毎フレーム同じ位置に保ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스마트 정렬이 모든 프레임에서 피사체를 같은 위치에 유지합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O alinhamento inteligente mantém o assunto no mesmo lugar em cada quadro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Умное выравнивание удерживает объект на одном месте в каждом кадре."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能对齐让主体在每一帧都保持在同一位置。"
          }
        }
      }
    },

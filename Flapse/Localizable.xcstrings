    "%@ için bugünkü kareni ekle.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضِف صورة اليوم لـ %@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge das heutige Bild für %@ hinzu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add today's frame for %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade la foto de hoy para %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute la photo du jour pour %@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ के लिए आज की फ़ोटो जोड़ें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ の今日の1枚を追加しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@의 오늘 사진을 추가하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione a foto de hoje para %@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте сегодняшний кадр для %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为 %@ 添加今天的照片。"
          }

    "Kamera başlatılamadı.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تشغيل الكاميرا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamera konnte nicht gestartet werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't start the camera."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo iniciar la cámara."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de démarrer la caméra."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैमरा शुरू नहीं हो सका।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラを起動できませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "카메라를 시작할 수 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível iniciar a câmera."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось запустить камеру."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法启动相机。"
          }
        }
      }
    },
    "Kamera izni ayarları": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إعدادات إذن الكاميرا"
          }

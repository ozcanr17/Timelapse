    "Videoyu kaydetmek için Ayarlar'dan Flapse'e Fotoğraflara ekleme izni ver.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "للحفظ، امنح Flapse إذن الإضافة إلى الصور من الإعدادات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaube Flapse in den Einstellungen, Fotos hinzuzufügen, um das Video zu sichern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To save the video, allow Flapse to add to Photos in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para guardar el vídeo, permite que Flapse añada a Fotos en Ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour enregistrer la vidéo, autorisez Flapse à ajouter à Photos dans Réglages."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वीडियो सहेजने के लिए सेटिंग्स में Flapse को Photos में जोड़ने की अनुमति दें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "動画を保存するには、設定でFlapseに写真への追加を許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동영상을 저장하려면 설정에서 Flapse의 사진 추가 권한을 허용하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Para salvar o vídeo, permita que o Flapse adicione a Fotos nos Ajustes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтобы сохранить видео, разрешите Flapse добавлять в Фото в настройках."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要保存视频，请在设置中允许 Flapse 添加到照片。"
          }

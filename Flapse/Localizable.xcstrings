    "Silinen fotoğraflar 30 gün saklanır, sonra kalıcı olarak silinir.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم الاحتفاظ بالصور المحذوفة لمدة 30 يومًا، ثم تُحذف نهائيًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelöschte Fotos werden 30 Tage lang aufbewahrt und dann endgültig gelöscht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleted photos are kept for 30 days, then permanently deleted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las fotos eliminadas se conservan durante 30 días y después se borran permanentemente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les photos supprimées sont conservées pendant 30 jours, puis supprimées définitivement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हटाई गई फ़ोटो 30 दिनों तक रखी जाती हैं, फिर स्थायी रूप से हटा दी जाती हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除した写真は30日間保存された後、完全に削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삭제된 사진은 30일 동안 보관된 후 영구 삭제됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As fotos eliminadas são mantidas durante 30 dias e depois apagadas permanentemente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалённые фотографии хранятся 30 дней, после чего удаляются навсегда."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已删除的照片会保留 30 天，之后将永久删除。"
          }
        }
      }
    },
    "Silinen proje yok": {
      "extractionState": "stale",
      "localizations": {

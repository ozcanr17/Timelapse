        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिछले फ़्रेम को गाइड की तरह देखें और हर बार वही कोण पाएँ"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前の写真をガイドにして、毎回同じアングルで撮影"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이전 프레임을 가이드로 보고 매번 같은 구도를 맞추세요"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a foto anterior como guia e mantenha sempre o mesmo ângulo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте предыдущий кадр как ориентир и сохраняйте один ракурс"

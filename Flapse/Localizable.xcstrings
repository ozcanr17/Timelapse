    "Giriş tamamlanamadı. Tekrar dene.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر إكمال تسجيل الدخول. حاول مجددًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anmeldung fehlgeschlagen. Versuch es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign-in couldn't be completed. Try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo iniciar sesión. Inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion a échoué. Réessaie."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साइन इन पूरा नहीं हो सका। फिर कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインインを完了できませんでした。もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인을 완료할 수 없습니다. 다시 시도하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível iniciar sessão. Tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось войти. Попробуйте ещё раз."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录未完成，请重试。"
          }
        }
      }
    },
    "Giriş yapmadan devam et": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",

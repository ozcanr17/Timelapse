      "İlk referans karedeki kişi sırası korunur; gerekirse kare otomatik çevrilir.": {
          "localizations": {
              "ar": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "يُحافَظ على ترتيب الشخصين في أول لقطة مرجعية؛ وتُعكس اللقطة تلقائيًا عند الحاجة."
                  }
              },
              "de": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "Die Personenreihenfolge des ersten Referenzbilds bleibt erhalten; bei Bedarf wird ein Bild automatisch gespiegelt."
                  }
              },
              "en": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "The person order in the first reference frame is preserved; a frame is flipped automatically when needed."
                  }
              },
              "es": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "Se conserva el orden de las personas del primer fotograma de referencia; si hace falta, el fotograma se voltea automáticamente."
                  }
              },
              "fr": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "L’ordre des personnes de la première image de référence est conservé ; une image est retournée automatiquement si nécessaire."
                  }
              },
              "hi": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "पहले रेफ़रेंस फ़्रेम में लोगों का क्रम बना रहता है; ज़रूरत होने पर फ़्रेम अपने-आप पलट जाता है।"
                  }
              },
              "ja": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "最初の基準写真の左右を保ち、必要な写真だけ自動で反転します。"
                  }
              },
              "ko": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "첫 기준 프레임의 사람 순서를 유지하며, 필요한 프레임은 자동으로 좌우 반전합니다."
                  }
              },
              "pt": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "A ordem das pessoas na primeira imagem de referência é mantida; a imagem é invertida automaticamente quando necessário."
                  }
              },
              "ru": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "Порядок людей в первом опорном кадре сохраняется; при необходимости кадр автоматически отражается."
                  }
              },
              "zh-Hans": {
                  "stringUnit": {
                      "state": "translated",
                      "value": "保持首张参考画面中的人物左右顺序；必要时会自动翻转画面。"
                  }
              }
          }
      }
    ,

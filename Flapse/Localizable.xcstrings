    "Mağaza şu an kullanılamıyor. İnternet bağlantını kontrol edip tekrar dene.": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المتجر غير متاح حاليًا. تحقق من اتصالك وحاول مجددًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Store ist gerade nicht verfügbar. Prüfe deine Verbindung und versuch es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The store is unavailable right now. Check your connection and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La tienda no está disponible ahora. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La boutique est indisponible pour le moment. Vérifie ta connexion et réessaie."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्टोर अभी उपलब्ध नहीं है। कनेक्शन जांचकर फिर कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ストアは現在利用できません。接続を確認して再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스토어를 지금 사용할 수 없습니다. 연결을 확인하고 다시 시도하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A loja está indisponível no momento. Verifique sua conexão e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Магазин сейчас недоступен. Проверьте подключение и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "商店暂时不可用。请检查网络后重试。"
          }
        }
      }
    },

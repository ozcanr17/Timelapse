        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका वीडियो तैयार है — इसे सहेजना न भूलें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "動画が完成しました。保存をお忘れなく。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동영상이 완성되었습니다. 저장하는 것을 잊지 마세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu vídeo está pronto — não esqueça de salvá-lo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Видео готово — не забудьте сохранить его."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "视频已完成，别忘了保存。"
          }
        }
      }
    },

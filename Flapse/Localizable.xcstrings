    "Timelapse için en az 2 kare gerekli.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج التايم لابس إلى صورتين على الأقل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Zeitraffer braucht mindestens 2 Bilder."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A timelapse needs at least 2 frames."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un timelapse necesita al menos 2 fotos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un timelapse demande au moins 2 photos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टाइमलैप्स के लिए कम से कम 2 फ़ोटो चाहिए।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タイムラプスには2枚以上必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "타임랩스에는 사진이 2장 이상 필요합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Um timelapse precisa de pelo menos 2 fotos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для таймлапса нужно минимум 2 кадра."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "延时视频至少需要 2 张照片。"
          }
        }
      }
    },

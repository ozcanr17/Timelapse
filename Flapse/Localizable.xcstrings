    "iCloud isteği kaydedildi; şu an yerel depoya düşülüyor (ücretli Apple hesabı gerekir).": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم حفظ طلب iCloud؛ يُستخدم التخزين المحلي حاليًا (يلزم حساب Apple مدفوع)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud-Anfrage gespeichert; derzeit wird lokal gespeichert (kostenpflichtiges Apple-Konto erforderlich)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud request saved; currently falling back to local storage (a paid Apple account is required)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitud de iCloud guardada; por ahora se usa almacenamiento local (se requiere cuenta de pago de Apple)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demande iCloud enregistrée ; stockage local utilisé pour l'instant (compte Apple payant requis)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud अनुरोध सहेजा गया; अभी स्थानीय स्टोरेज का उपयोग हो रहा है (सशुल्क Apple खाता आवश्यक है)।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloudの設定を保存しました。現在はローカルストレージを使用しています（有料のAppleアカウントが必要です）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 요청이 저장되었습니다. 현재는 로컬 저장 공간을 사용합니다(유료 Apple 계정 필요)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O pedido do iCloud foi guardado; de momento está a ser usado o armazenamento local (é necessária uma conta Apple paga)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запрос iCloud сохранён; сейчас используется локальное хранилище (требуется платная учётная запись Apple)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 请求已保存；目前将使用本地存储（需要付费 Apple 帐户）。"
          }
        }
      }
    },

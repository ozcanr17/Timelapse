          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a timelapse from a project, tap \"Keep in app\", and it'll collect here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando crees un timelapse desde un proyecto y toques \"Conservar en la app\", se guardará aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Crée un timelapse depuis un projet, touche « Garder dans l'app » et il apparaîtra ici."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी प्रोजेक्ट से टाइमलैप्स बनाकर \"ऐप में रखें\" पर टैप करने पर वे यहां जमा होते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロジェクトからタイムラプスを作成して「アプリ内に保存」をタップすると、ここに集まります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프로젝트에서 타임랩스를 만들고 \"앱에 보관\"을 누르면 여기에 모여요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie um timelapse em um projeto e toque em \"Manter no app\" para vê-lo aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создай таймлапс из проекта и нажми «Хранить в приложении» — он появится здесь."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在项目中生成延时视频并点按“保留在应用中”后，就会收集到这里。"
          }
        }
      }
    },

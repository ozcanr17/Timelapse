    "Geri yüklenecek bir abonelik bulunamadı.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يُعثر على اشتراك لاستعادته."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Abo zum Wiederherstellen gefunden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No subscription found to restore."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se encontró ninguna suscripción para restaurar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun abonnement à restaurer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिस्टोर करने के लिए कोई सब्सक्रिप्शन नहीं मिला।"
          }
        },
        "ja": {
          "stringUnit": {

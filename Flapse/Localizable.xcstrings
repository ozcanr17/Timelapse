    "Videon oluşturuldu, kaydetmeyi unutma.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الفيديو جاهز — لا تنسَ حفظه."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Video ist fertig – vergiss nicht, es zu sichern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your video is ready — don't forget to save it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu vídeo está listo: no olvides guardarlo."
          }
        },
        "fr": {

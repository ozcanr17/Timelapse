          }
        }
      }
    },
    "Kamera izni verilmedi. Ayarlar’dan açabilirsin.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يُمنح إذن الكاميرا. يمكنك تفعيله من الإعدادات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamerazugriff nicht erlaubt. Du kannst ihn in den Einstellungen aktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access wasn't granted. You can enable it in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se concedió acceso a la cámara. Puedes activarlo en Ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès à la caméra n'a pas été accordé. Tu peux l'activer dans Réglages."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैमरा की अनुमति नहीं दी गई। सेटिंग्स में चालू कर सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラへのアクセスが許可されていません。設定で有効にできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "카메라 접근이 허용되지 않았습니다. 설정에서 켤 수 있어요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à câmera não foi concedido. Você pode ativá-lo nos Ajustes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к камере не предоставлен. Его можно включить в Настройках."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未授予相机权限。可在设置中开启。"
          }
        }
      }
    },

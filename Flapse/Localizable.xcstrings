      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تبقى صورك على جهازك؛ ولا يُرسل شيء دون إذنك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Fotos bleiben auf deinem Gerät; ohne dein Zutun wird nichts hochgeladen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your photos stay on your device; nothing is uploaded unless you choose to."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus fotos se quedan en tu dispositivo; nada se sube sin que tú lo decidas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tes photos restent sur ton appareil ; rien n'est envoyé sans ton accord."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी फ़ोटो आपके डिवाइस पर ही रहती हैं; आपकी मर्ज़ी के बिना कहीं नहीं भेजी जातीं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真は端末に保存され、あなたの許可なく送信されることはありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진은 기기에만 저장되며, 허락 없이 어디에도 전송되지 않습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Suas fotos ficam no seu aparelho; nada é enviado sem você querer."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваши фото остаются на устройстве; без вашего согласия ничего никуда не отправляется."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的照片保存在设备上；未经你允许不会上传。"
          }
        }
      }
    },
    "Fotoğrafların hep güvende": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "صورك في أمان دائمًا"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Fotos, immer sicher"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your photos, always safe"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus fotos, siempre seguras"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tes photos, toujours en sécurité"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी फ़ोटो हमेशा सुरक्षित"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真をいつも安全に"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진을 언제나 안전하게"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Suas fotos, sempre seguras"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваши фото всегда в безопасности"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的照片始终安全"
          }
        }
      }
    },
    "Apple ile giriş ve iCloud hesabı ayrıdır. Eşitleme için bu cihazın Ayarlar uygulamasında aynı iCloud hesabı açık olmalı.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تسجيل الدخول باستخدام Apple وحساب iCloud منفصلان. للمزامنة، يجب تسجيل هذا الجهاز في حساب iCloud نفسه من تطبيق الإعدادات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit Apple anmelden und das iCloud-Konto sind getrennt. Für die Synchronisierung muss dieses Gerät in den Einstellungen mit demselben iCloud-Konto angemeldet sein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in with Apple and your iCloud account are separate. To sync, this device must be signed in to the same iCloud account in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar sesión con Apple y la cuenta de iCloud son independientes. Para sincronizar, este dispositivo debe usar la misma cuenta de iCloud en Ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Se connecter avec Apple et le compte iCloud sont distincts. Pour synchroniser, cet appareil doit utiliser le même compte iCloud dans Réglages."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple से साइन इन और iCloud खाता अलग हैं। सिंक के लिए इस डिवाइस की सेटिंग्स में वही iCloud खाता साइन इन होना चाहिए।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AppleでサインインとiCloudアカウントは別のものです。同期するには、このデバイスの設定で同じiCloudアカウントにサインインしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple로 로그인과 iCloud 계정은 별개입니다. 동기화하려면 이 기기의 설정에서 동일한 iCloud 계정으로 로그인해야 합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar sessão com a Apple e a conta iCloud são separados. Para sincronizar, este dispositivo deve usar a mesma conta iCloud nos Ajustes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вход с Apple и учётная запись iCloud — разные вещи. Для синхронизации на устройстве должна быть выбрана та же учётная запись iCloud в Настройках."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 Apple 登录与 iCloud 帐户相互独立。要同步，此设备必须在“设置”中登录同一个 iCloud 帐户。"
          }
        }
      }
    },
    "Fotoğrafların iCloud'a kaydediliyor; aynı hesapla giren her cihazda geri gelir.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُحفظ صورك في iCloud وتعود على أي جهاز بالحساب نفسه."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Fotos werden in iCloud gesichert und kommen auf jedem Gerät mit demselben Konto zurück."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your photos are saved to iCloud and come back on any device with the same account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus fotos se guardan en iCloud y vuelven en cualquier dispositivo con la misma cuenta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tes photos sont enregistrées dans iCloud et reviennent sur tout appareil avec le même compte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी फ़ोटो iCloud में सहेजी जाती हैं और उसी खाते वाले हर डिवाइस पर वापस आती हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真は iCloud に保存され、同じアカウントの端末で復元されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진이 iCloud에 저장되며 같은 계정의 모든 기기에서 복원됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Suas fotos são salvas no iCloud e voltam em qualquer aparelho com a mesma conta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фото сохраняются в iCloud и возвращаются на любом устройстве с той же учётной записью."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的照片已保存到 iCloud，任何使用同一账户的设备都能找回。"
          }
        }
      }
    },
    "Fotoğrafların şu an yalnızca bu cihazda. Eşitleme için Pro + iCloud yedekleme gerekir; açtıktan sonra uygulamayı yeniden başlat.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "صورك على هذا الجهاز فقط حاليًا. تتطلب المزامنة Pro ونسخ iCloud الاحتياطي؛ أعد تشغيل التطبيق بعد التفعيل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Fotos sind derzeit nur auf diesem Gerät. Für die Synchronisierung sind Pro + iCloud-Backup nötig; danach App neu starten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your photos are only on this device right now. Syncing needs Pro + iCloud backup; restart the app after enabling."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus fotos están solo en este dispositivo. La sincronización requiere Pro + copia de iCloud; reinicia la app tras activarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tes photos ne sont que sur cet appareil. La synchro demande Pro + sauvegarde iCloud ; redémarre l'app après activation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी फ़ोटो अभी केवल इसी डिवाइस पर हैं। सिंक के लिए Pro + iCloud बैकअप चाहिए; चालू करने के बाद ऐप री-स्टार्ट करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真は現在この端末のみにあります。同期には Pro と iCloud バックアップが必要です。有効化後にアプリを再起動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진이 현재 이 기기에만 있습니다. 동기화에는 Pro와 iCloud 백업이 필요하며, 켠 후 앱을 재시작하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Suas fotos estão apenas neste aparelho. A sincronização exige Pro + backup do iCloud; reinicie o app após ativar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фото пока только на этом устройстве. Для синхронизации нужны Pro и резервная копия iCloud; после включения перезапустите приложение."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的照片目前仅在本机。同步需要 Pro + iCloud 备份；开启后请重启应用。"
          }
        }
      }
    },
    "Fotoğrafı sürükleyerek özneyi ortala": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسحب الصورة لتوسيط الهدف"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehe das Foto, um das Motiv zu zentrieren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag the photo to center the subject"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra la foto para centrar el sujeto"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fais glisser la photo pour centrer le sujet"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ोटो खींचकर विषय को बीच में लाएं"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真をドラッグして被写体を中央に"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진을 드래그해 피사체를 가운데로"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Arraste a foto para centralizar o objeto"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите фото, чтобы отцентрировать объект"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖动照片使主体居中"
          }
        }
      }
    },
    "Fotoğrafı sürükleyerek özneyi ortala; her kareyi ayrı ayrı hizalayabilirsin": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسحب لتوسيط الهدف؛ يمكنك محاذاة كل صورة على حدة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehe, um das Motiv zu zentrieren; jedes Bild lässt sich einzeln ausrichten"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag to center the subject; you can align every frame individually"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra para centrar el sujeto; puedes alinear cada foto por separado"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fais glisser pour centrer le sujet ; chaque photo peut être alignée séparément"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "विषय को बीच में लाने के लिए खींचें; हर फ़ोटो अलग से संरेखित कर सकते हैं"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドラッグして被写体を中央に。写真ごとに個別調整できます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "드래그해 피사체를 가운데로. 사진마다 개별 정렬할 수 있어요"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Arraste para centralizar o objeto; você pode alinhar cada foto separadamente"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите, чтобы отцентрировать объект; каждый кадр можно выровнять отдельно"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖动以居中主体；每张照片都可单独对齐"
          }
        }
      }
    },

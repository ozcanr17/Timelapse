            "value": "Manter no app"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Хранить в приложении"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保留在应用中"
          }
        }
      }
    },
    "Uygulamadan çıksan da oluşturma sürer; biten video Kaydedilenler'e düşer.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستمر الإنشاء حتى لو خرجت من التطبيق، وسيظهر الفيديو الجاهز في المحفوظات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Erstellung läuft weiter, auch wenn du die App verlässt; das fertige Video landet unter „Gesichert“."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rendering continues even if you leave the app; the finished video lands in Saved."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aunque salgas de la app, la creación continúa; el vídeo terminado aparecerá en Guardados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La création continue même si tu quittes l'app ; la vidéo terminée arrive dans Enregistrés."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप से बाहर जाने पर भी बनना जारी रहता है; तैयार वीडियो सहेजे गए में आ जाता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリを閉じても作成は続行され、完成した動画は保存済みに追加されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱을 나가도 계속 만들어져요. 완성된 영상은 보관함에 저장돼요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A criação continua mesmo se você sair do app; o vídeo pronto vai para Salvos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создание продолжится, даже если выйдешь из приложения; готовое видео появится в «Сохранённом»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即使退出应用，生成也会继续；完成的视频会出现在“已存”中。"
          }
        }
      }
    },

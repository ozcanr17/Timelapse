    "Önceki karen kameranın üzerinde silik görünür; her fotoğraf aynı açıdan çekilir": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر صورتك السابقة شفافة فوق الكاميرا؛ فتلتقط كل صورة من الزاوية نفسها"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein voriges Bild erscheint blass über der Kamera; jedes Foto gelingt aus demselben Winkel"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your previous frame shows faintly over the camera, so every photo lines up the same way"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu foto anterior aparece tenue sobre la cámara; cada foto sale desde el mismo ángulo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta photo précédente apparaît en filigrane sur la caméra ; chaque photo garde le même angle"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिछली फ़ोटो कैमरे पर हल्की दिखती है; हर फ़ोटो एक ही कोण से आती है"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前回の写真がカメラにうっすら重なり、毎回同じアングルで撮れます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이전 사진이 카메라 위에 흐릿하게 겹쳐 보여 매번 같은 각도로 찍을 수 있어요"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua foto anterior aparece translúcida sobre a câmera; cada foto sai do mesmo ângulo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прошлый кадр слегка виден поверх камеры — каждое фото получается с того же ракурса"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "上一张照片会淡淡地叠在取景器上；每张照片都保持同一角度"
          }
        }
      }
    },
    "Önceki karen kameranın üzerinde silik görünür; videoda kareler otomatik hizalanır": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر لقطتك السابقة باهتة فوق الكاميرا؛ وتُحاذى الإطارات تلقائيًا في الفيديو"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine vorherige Aufnahme erscheint blass über der Kamera; im Video richten sich die Bilder automatisch aus"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your previous shot appears faintly over the camera; frames auto-align in the video"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu foto anterior aparece tenue sobre la cámara; los fotogramas se alinean automáticamente en el vídeo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre photo précédente apparaît en filigrane sur la caméra ; les images s'alignent automatiquement dans la vidéo"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी पिछली फोटो कैमरे पर हल्की दिखती है; वीडियो में फ्रेम अपने आप संरेखित होते हैं"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前回の写真がカメラにうっすら重なって表示され、動画ではフレームが自動で揃います"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이전 사진이 카메라 위에 흐릿하게 표시되고, 영상에서는 프레임이 자동으로 정렬됩니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua foto anterior aparece esmaecida sobre a câmera; os quadros se alinham automaticamente no vídeo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предыдущий снимок бледно виден поверх камеры; кадры в видео выравниваются автоматически"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "上一张照片会淡淡地叠加在取景器上；视频中的帧会自动对齐"
          }
        }
      }
    },
    "Önceki kareyi şablon olarak gör, hep aynı açıyı yakala": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم اللقطة السابقة كدليل وحافظ على الزاوية نفسها كل مرة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieh das vorige Bild als Vorlage und triff immer denselben Winkel"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See the previous frame as a template and nail the same angle every time"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la foto anterior como plantilla y repite siempre el mismo ángulo"

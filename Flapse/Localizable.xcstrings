    "Her gün aynı ışıkta çekersen geçişler daha pürüzsüz olur.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "صوّر في الإضاءة نفسها كل يوم لتحصل على انتقالات أكثر سلاسة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografiere täglich bei gleichem Licht für weichere Übergänge."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shoot in the same light every day for smoother transitions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz las fotos con la misma luz cada día para transiciones más suaves."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Photographiez chaque jour sous la même lumière pour des transitions plus fluides."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हर दिन एक जैसी रोशनी में शूट करें, ट्रांज़िशन और स्मूद होंगे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "毎日同じ光で撮ると、切り替わりがより滑らかに。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "매일 같은 조명에서 촬영하면 전환이 더 부드러워집니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografe com a mesma luz todos os dias para transições mais suaves."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Снимайте каждый день при одинаковом освещении — переходы будут плавнее."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每天在相同光线下拍摄，过渡会更顺滑。"
          }
        }
      }
    },
    "Her gün, gün aşırı ya da haftalık — zamanı gelince hatırla": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يوميًا أو يومًا بعد يوم أو أسبوعيًا — سنذكّرك عندما يحين الموعد"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Täglich, jeden zweiten Tag oder wöchentlich — werde rechtzeitig erinnert"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Daily, every other day or weekly — get reminded when it's time"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Diario, cada dos días o semanal — recibe un recordatorio a tiempo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque jour, un jour sur deux ou chaque semaine — sois rappelé au bon moment"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रोज़, हर दूसरे दिन या साप्ताहिक — समय आने पर रिमाइंडर पाएँ"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "毎日・隔日・毎週から選び、撮影のタイミングで通知"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "매일, 격일 또는 매주 — 촬영할 때가 되면 알려드려요"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os dias, em dias alternados ou semanalmente — receba um lembrete na hora certa"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждый день, через день или еженедельно — напоминание придёт вовремя"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每天、隔天或每周——到时间时提醒你"
          }
        }
      }
    },
    "Her kareyi elle hizala, döndür ve yakınlaştır": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حاذِ كل إطار يدويًا ودوّره وقرّبه"

    "Fiyatlar yüklenemedi. Bağlantını kontrol edip tekrar dene.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تحميل الأسعار. تحقق من اتصالك وحاول مجددًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Preise konnten nicht geladen werden. Prüfe deine Verbindung und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Prices couldn't be loaded. Check your connection and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudieron cargar los precios. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger les prix. Vérifie ta connexion et réessaie."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कीमतें लोड नहीं हो सकीं। कनेक्शन जांचकर फिर से आज़माएं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "価格を読み込めませんでした。接続を確認して再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가격을 불러오지 못했습니다. 연결을 확인하고 다시 시도하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível carregar os preços. Verifique sua conexão e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить цены. Проверьте подключение и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法加载价格。请检查网络后重试。"
          }
        }
      }
    },

            "value": "不登录继续"
          }
        }
      }
    },
    "Giriş yapıldı. Bu hesap admin değil; Pro açılmadı.": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تسجيل الدخول. هذا الحساب ليس حساب مشرف، لذلك لم يتم تفعيل Pro."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Angemeldet. Dieses Konto ist kein Admin; Pro wurde nicht freigeschaltet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Signed in. This account isn't an admin; Pro was not unlocked."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesión iniciada. Esta cuenta no es admin; Pro no se desbloqueó."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connecté. Ce compte n'est pas admin ; Pro n'a pas été débloqué."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साइन इन हो गया। यह एडमिन खाता नहीं है, इसलिए Pro चालू नहीं हुआ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインインしました。このアカウントは管理者ではないため、Proは有効になりませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인했습니다. 관리자 계정이 아니므로 Pro가 활성화되지 않았습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessão iniciada. Esta não é uma conta de administrador, por isso o Pro não foi ativado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вход выполнен. Это не учётная запись администратора, поэтому Pro не активирован."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已登录。此帐户不是管理员帐户，因此 Pro 未启用。"
          }
        }
      }
    },

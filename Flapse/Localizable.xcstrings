    "Sağ üstteki + ile bir proje oluştur,\nzamanla değişimi kaydetmeye başla.": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنشئ مشروعًا باستخدام + في أعلى اليسار،\nوابدأ بتسجيل التغيير مع مرور الوقت."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle mit dem + oben rechts ein Projekt\nund halte Veränderung über die Zeit fest."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a project with the + up top,\nand start capturing change over time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un proyecto con el + de arriba\ny empieza a registrar el cambio con el tiempo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Crée un projet avec le + en haut à droite\net commence à capturer le changement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऊपर दिए + से प्रोजेक्ट बनाएँ\nऔर समय के साथ बदलाव दर्ज करना शुरू करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "右上の＋からプロジェクトを作成し、\n時間とともに変わる様子を記録しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오른쪽 상단의 +로 프로젝트를 만들고\n시간에 따른 변화를 기록해 보세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie um projeto com o + no canto superior direito\ne comece a registar a mudança ao longo do tempo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создайте проект кнопкой «+» вверху справа\nи начните фиксировать изменения со временем."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "轻点右上角的“+”创建项目，\n开始记录随时间发生的变化。"
          }
        }
      }
    },
    "Sağ üstteki kamera düğmesiyle ilk çekimini ekle.": {
      "localizations": {
        "ar": {
          "stringUnit": {

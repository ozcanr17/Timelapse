  "strings": {
    "Face ID veya cihaz parolanla aç.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح باستخدام بصمة الوجه أو رمز دخول الجهاز."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit Face ID oder Gerätecode öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open with Face ID or your device passcode."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre con Face ID o el código del dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez avec Face ID ou le code de l’appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Face ID या डिवाइस पासकोड से खोलें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Face IDまたはデバイスのパスコードで開きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Face ID 또는 기기 암호로 여세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra com Face ID ou o código do dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте с помощью Face ID или код-пароля устройства."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Face ID veya cihaz parolanla aç."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用面容 ID 或设备密码打开。"
          }
        }
      }
    },
